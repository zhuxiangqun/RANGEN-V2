# RANGEN Configuration

# LLM Provider (deepseek, openai, stepflash, or mock)
LLM_PROVIDER=mock

# DeepSeek API (if using deepseek)
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
REASONING_MODEL=deepseek-reasoner
VALIDATION_MODEL=deepseek-chat
CITATION_MODEL=deepseek-chat

# Step-3.5-Flash API (if using stepflash)
STEPSFLASH_API_KEY=your_stepflash_api_key_here

# Knowledge Base
VECTOR_STORE_PATH=./data/vector_store
EMBEDDING_MODEL=text-embedding-3-small

# System Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
