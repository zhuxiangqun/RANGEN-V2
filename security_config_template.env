# 安全配置模板文件
# 复制此文件为 .env 并设置实际的安全值
# 警告: 不要将包含真实凭证的 .env 文件提交到版本控制系统

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=postgresql://username:password@localhost:5432/rangen

# ===========================================
# API服务配置
# ===========================================
API_HEALTH_ENDPOINT=http://localhost:8080/health
REDIS_URL=redis://localhost:6379

# ===========================================
# 管理员账户配置
# ===========================================
ADMIN_PASSWORD=your_secure_admin_password_here

# ===========================================
# 外部服务API密钥
# ===========================================
JINA_API_KEY=your_jina_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# 其他敏感配置
# ===========================================
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here
SESSION_SECRET=your_session_secret_here

# ===========================================
# 生产环境部署路径
# ===========================================
PRODUCTION_DEPLOYMENT_PATH=/opt/rangen/production
STAGING_DEPLOYMENT_PATH=/opt/rangen/staging
BACKUP_PATH=/opt/rangen/backup
