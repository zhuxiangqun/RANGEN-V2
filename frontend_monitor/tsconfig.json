{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client"],
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "vueCompilerOptions": {
    "target": 3,
    "experimentalCompatMode": 2,
    "jsxTemplates": false,
    "globalTypesPath": "./.volar/vue-global.d.ts"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/env.d.ts",
    "src/shims-vue.d.ts",
    "vue-shim.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

