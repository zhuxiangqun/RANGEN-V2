# Gateway Configuration
# Add these to your .env file or use directly

# ===========================================
# Gateway Settings
# ===========================================

# Gateway Mode
GATEWAY_ENABLED=true
GATEWAY_PORT=8765

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_PER_MINUTE=20

# Heartbeat
HEARTBEAT_INTERVAL=60

# ===========================================
# Channel Configuration
# ===========================================

# Telegram (get token from @BotFather)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Slack (create app at https://api.slack.com)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your_signing_secret

# WebChat (built-in, no config needed)
# WEBCHAT_PORT=8765

# WhatsApp (requires baileys - more complex setup)
# WHATSAPP_AUTH_DIR=./data/whatsapp_auth

# ===========================================
# Security
# ===========================================

# Sandbox Mode (experimental)
# SANDBOX_ENABLED=false

# Tool Policy
# TOOL_POLICY_STRICT=false
# MAX_TOOL_CALLS_PER_REQUEST=10

# ===========================================
# Memory
# ===========================================

# Memory Settings
MEMORY_ENABLED=true
MEMORY_TTL_DAYS=7

# ===========================================
# Existing RANGEN Settings (keep these)
# ===========================================

# LLM Provider (deepseek, openai, or mock)
LLM_PROVIDER=mock

# DeepSeek API (if using deepseek)
# DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
